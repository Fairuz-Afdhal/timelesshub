# Shared themed 404 (served from ./shared for every static site)
(shared_404) {
	handle_errors {
		@404 expression `{err.status_code} == 404`
		handle @404 {
			root * /srv/shared
			rewrite * /404.html
			file_server
		}
	}
}

# Static asset caching (long for assets, short for HTML)
(static_cache) {
	@static {
		path *.css *.js *.svg *.png *.jpg *.jpeg *.webp *.woff2
	}
	header @static Cache-Control "public, max-age=2592000, immutable"
	header *.html Cache-Control "public, max-age=300"
}

# Homepage / hub (static site served from ./site)
timelesshub.my.id {
	encode zstd gzip
	root * /srv/timelesshub
	file_server
	import shared_404
	import static_cache
}

# Personal portfolio (static site served from ./portfolio)
fairuz.timelesshub.my.id {
	root * /srv/fairuz
	encode zstd gzip
	file_server
	import shared_404
	import static_cache
}

# Stremio addons (reverse-proxied to their containers)
comet.timelesshub.my.id {
	reverse_proxy comet:8000
}

aio.timelesshub.my.id {
	reverse_proxy aiostreams:3000
}
